<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>AuraOS</string>
    <key>CFBundleDisplayName</key>
    <string>AuraOS</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>

    <!-- Privacy Permission Descriptions -->
    <key>NSMicrophoneUsageDescription</key>
    <string>AuraOS records voice notes for on-device transcription and AI categorization. Audio never leaves your device.</string>
    <key>NSCameraUsageDescription</key>
    <string>AuraOS uses the camera when you ask to take a photo via voice command.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>AuraOS uses on-device speech recognition for offline voice transcription.</string>
    <key>NSContactsUsageDescription</key>
    <string>AuraOS accesses contacts to help you call, message, or look up people by name.</string>
    <key>NSCalendarsFullAccessUsageDescription</key>
    <string>AuraOS reads and creates calendar events on your behalf via voice commands.</string>
    <key>NSRemindersFullAccessUsageDescription</key>
    <string>AuraOS creates and reads reminders from your voice commands.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>AuraOS uses your location to add context to voice notes and actions.</string>
    <key>NSHealthShareUsageDescription</key>
    <string>AuraOS reads health data to answer your wellness queries.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>AuraOS can log health data when you request it via voice.</string>

    <!-- Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>fetch</string>
    </array>
</dict>
</plist>
